{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TI工具箱",
  "version": "0.2.0",
  "identifier": "com.titoolbox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TI工具箱",
        "width": 1080,
        "height": 760,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2QTI3MzcyQUQ2M0YzRkMKUldUODgyT3Rjbk9pUmt2S3hhNWo0TjZhZm5uV0ZxZ0JvTkZnL0tvY0VlMHFFdHYvVjVHQTJBelIK",
      "endpoints": [
        "https://github.com/zuoliangyu/ti-toolbox/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
